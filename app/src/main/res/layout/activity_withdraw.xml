<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏦 Withdraw to Bank"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvWithdrawBankName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#1565C0"
        android:layout_marginBottom="4dp"
        android:text="Bank: —"/>

    <TextView
        android:id="@+id/tvWithdrawOfflineBal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#555555"
        android:layout_marginBottom="24dp"
        android:text="Offline wallet: ₹0"/>

    <EditText
        android:id="@+id/etWithdrawAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount to withdraw (₹)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etWithdrawUpiPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="UPI PIN"
        android:inputType="numberPassword"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnConfirmWithdraw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Withdraw to Main Account"
        android:layout_marginBottom="12dp"/>

    <ProgressBar
        android:id="@+id/progressWithdraw"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvWithdrawStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:layout_marginBottom="24dp"
        android:text=""/>

    <Button
        android:id="@+id/btnBackFromWithdraw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back"
        style="@style/Widget.AppCompat.Button.Borderless"/>

</LinearLayout>