<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Green header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16A34A"
        android:padding="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Receive Payment"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose how to receive money"
            android:textColor="#BBF7D0"
            android:textSize="13sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card 1: Show my QR (Merchant mode) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="24dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="16dp">
                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/circle_green_bg"/>
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:id="@+id/ivReceiveQr"
                        android:scaleType="centerInside"
                        android:padding="12dp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate QR Code"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show your QR for payer to scan and pay"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvUserId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"
                    android:text="user_id"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Merchant Mode"
                    android:textColor="#16A34A"
                    android:textSize="12sp"
                    android:background="@drawable/chip_green"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnShowMyQr"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#16A34A"
                    android:background="@drawable/circle_green_outline"
                    android:elevation="0dp"/>

            </LinearLayout>

            <!-- Card 2: Scan proof QR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="24dp"
                android:gravity="center">

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="16dp">
                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/circle_orange_bg"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="📱"
                        android:textSize="32sp"
                        android:gravity="center"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan Payment QR"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan the QR shown on payer's phone to confirm"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan &amp; Confirm"
                    android:textColor="#F59E0B"
                    android:textSize="12sp"
                    android:background="@drawable/chip_orange"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnScanProof"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#F59E0B"
                    android:background="@drawable/circle_orange_outline"
                    android:elevation="0dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>